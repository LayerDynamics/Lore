# ============================================
# Trellio — Trello MCP Server Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Required: Trello API ===
# Get these at: https://trello.com/power-ups/admin
TRELLO_API_KEY=
TRELLO_TOKEN=

# === Optional: Board Configuration ===
# If not set, use trellio_list_boards to discover your boards
# then trellio_get_board to get list/label IDs
TRELLO_BOARD_ID=

# List IDs (optional — discovered dynamically if not set)
TRELLO_LIST_REFERENCE_ID=
TRELLO_LIST_THIS_WEEK_ID=
TRELLO_LIST_TODAY_ID=
TRELLO_LIST_DOING_ID=
TRELLO_LIST_DONE_ID=

# Label IDs (optional — discovered dynamically if not set)
TRELLO_LABEL_HIGH_ENERGY_ID=
TRELLO_LABEL_MEDIUM_ENERGY_ID=
TRELLO_LABEL_LOW_ENERGY_ID=
TRELLO_LABEL_BRAIN_DEAD_ID=
TRELLO_LABEL_DUE_SOON_ID=

# === Optional: Project Directory ===
PROJECT_DIR=.
